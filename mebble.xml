<!-- Set terminal background color: #212121 -->
<!-- Set terminal foreground color: #eeffff -->
<!DOCTYPE highlight [
  <!ENTITY black "212121">
  <!ENTITY blue "82aaff">
  <!ENTITY bold "FF9800">
  <!ENTITY cyan "89ddff">
  <!ENTITY error "ff5370">
  <!ENTITY gray "616161">
  <!ENTITY green "c3e88d">
  <!ENTITY orange "f78c6c">
  <!ENTITY purple "c792ea">
  <!ENTITY red "f07178">
  <!ENTITY teal "80cbc4">
  <!ENTITY white "eeffff">
  <!ENTITY yellow "ffcb6b">
]>

<settings>
    <highlight fg='&gray;'>^\[.*?\](?:>|&gt;).*$</highlight>
    <highlight fg='&gray;'>\([0-9][0-9]\:[0-9][0-9]\:[0-9][0-9]\)$</highlight>
    <highlight fg='&blue;'>^--- Lich:.*</highlight>
    <preset id='whisper' fg='&yellow;'/>
    <preset id='speech' fg='&yellow;'/>
    <preset id='roomName' fg='&green;'/>
    <preset id='monsterbold' fg='&yellow;'/>
    <key id='enter' action='send_command'/>
    <key id='left' action='cursor_left'/>
    <key id='right' action='cursor_right'/>
    <key id='backspace' action='cursor_backspace'/>
    <key id='tab' action='switch_current_window'/>
    <key id='page_up' action='scroll_current_window_up_page'/>
    <key id='page_down' action='scroll_current_window_down_page'/>
    <key id='up' action='previous_command'/>
    <key id='down' action='next_command'/>
    <layout id='default'>
        <window class='text' top='15' left='28' height='lines-16' width='cols-28' value='main,combat' buffer-size='3000' />
        <window class='indicator' top='lines-1' left='28' height='1' width='1' label='&gt;' value='prompt' />
        <window class='command' top='lines-1' left='29' height='1' width='cols-29' />

        <!-- top bar -->
        <window class='text' top='0' left='0' height='14' width='(cols/2)' value='lnet,thoughts,voln' buffer-size='1000' timestamp='true' />
        <window class='text' top='0' left='(cols/2)' height='14' width='(cols/2)' value='talk,whispers,death,ooc' buffer-size='1000' />

        <!-- side bar -->
        <window class='exp' top='15' left='0' height='lines-25' width='28' value='exp' buffer-size='2000' />
        <window class='progress' top='lines-3' left='14' height='1' width='13' label='Mana:' value='mana' fg='&black;' bg='&blue;' />
        <window class='progress' top='lines-3' left='0' height='1' width='13' label='Stamina:' value='stamina' fg='&black;' bg='&teal;' />
        <window class='progress' top='lines-2' left='14' height='1' width='13' label='Health:' value='health' fg='&black;' bg='&green;' />
        <window class='progress' top='lines-2' left='0' height='1' width='13' label='Spirit:' value='spirit' fg='&black;' bg='&purple;' />
        <window class='countdown' top='lines-1' left='14' height='1' width='13' label='Roundtime:' value='roundtime' fg='&gray;,&black;,&black;,&white;' bg='nil,&error;,&cyan;' />
        <window class='progress' top='lines-1' left='0' height='1' width='13' label='Concen:' value='concentration' fg='&black;' bg='&gray;' />

        <window class='indicator' top='lines-7' left='2' height='1' width='3' label='S:' fg='&white;'/>
        <window class='indicator' top='lines-7' left='5' height='1' width='17' label=' ' value='spell' fg='&gray;,&yellow;' />
        <window class='indicator' top='lines-8' left='2' height='1' width='3' label='R:' fg='&white;' />
        <window class='indicator' top='lines-8' left='5' height='1' width='17' label=' ' value='right' fg='&gray;,&yellow; '/>
        <window class='indicator' top='lines-9' left='2' height='1' width='3' label='L:' fg='&white;'/>
        <window class='indicator' top='lines-9' left='5' height='1' width='17' label=' ' value='left' fg='&gray;,&yellow; '/>

        <window class='indicator' top='lines-5' left='2' height='1' width='3' label='STN' value='stunned' fg='&gray;,&yellow;' />
        <window class='indicator' top='lines-5' left='6' height='1' width='3' label='PSN' value='poisoned' fg='&gray;,&yellow;' />
        <window class='indicator' top='lines-5' left='10' height='1' width='3' label='DIS' value='diseased' fg='&gray;,&yellow;' />
        <window class='indicator' top='lines-5' left='14' height='1' width='3' label='HID' value='hidden' fg='&gray;,&yellow;' />
        <window class='indicator' top='lines-5' left='18' height='1' width='3' label='INV' value='invisible' fg='&gray;,&yellow;' />
        <window class='indicator' top='lines-5' left='22' height='1' width='3' label='BLD' value='bleeding' fg='&gray;,&yellow;' />
    </layout>
</settings>
